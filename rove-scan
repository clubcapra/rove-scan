@dataclass
class DeviceState:
    name: str
    ip: str
    up: bool = False
    latency: Optional[float] = None
    since: Optional[datetime] = None  # when the current state began
    history: list = field(default_factory=list)  # latency per poll; None = lost


def ping(ip: str, timeout: float = 1.0):
    """Ping once. Return (is_up, latency_ms_or_None)."""
    system = platform.system().lower()
    if system == "windows":
        cmd = ["ping", "-n", "1", "-w", str(int(timeout * 1000)), ip]
    elif system == "darwin":  # macOS uses -W in milliseconds
        cmd = ["ping", "-c", "1", "-W", str(int(timeout * 1000)), ip]
    else:  # linux: -W in seconds
        cmd = ["ping", "-c", "1", "-W", str(max(1, int(round(timeout)))), ip]

    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout + 2
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return False, None

    if result.returncode != 0:
        return False, None

    m = re.search(r"time[=<]\s*([\d.]+)", result.stdout)
    latency = float(m.group(1)) if m else None
    return True, latency


class Monitor:
    def __init__(self, groups, timeout, logpath, hidden=None):
        self.groups = groups
        self.timeout = timeout
        self.logpath = logpath
        self.hidden = hidden or set()
        self.state = {}
        for items in groups.values():
            for name, octet in items:
                ip = f"{SUBNET}.{octet}"
                self.state[ip] = DeviceState(name=name, ip=ip)
        self._baseline_done = False
        self._log(f"monitor started — watching {len(self.state)} devices")

    def _flat(self):
        out = []
        for items in self.groups.values():
            for name, octet in items:
                out.append((name, f"{SUBNET}.{octet}"))
        return out

    def poll(self):
        flat = self._flat()
        with ThreadPoolExecutor(max_workers=min(32, len(flat))) as ex:
            futs = {ex.submit(ping, ip, self.timeout): ip for _, ip in flat}
            for fut in as_completed(futs):
                ip = futs[fut]
                up, lat = fut.result()
                self._update(ip, up, lat)
        self._baseline_done = True

    def _update(self, ip, up, lat):
        st = self.state[ip]
        st.latency = lat if up else None
        # up-but-unparsed latency -> 0.0 (min bar); down -> None (max bar)
        st.history.append((lat if lat is not None else 0.0) if up else None)
        if len(st.history) > MAX_HISTORY:
            del st.history[:-MAX_HISTORY]
        changed = st.up != up
        if changed and self._baseline_done:
            self._log_change(st.name, ip, up)
        if changed or st.since is None:
            st.up = up
            st.since = datetime.now()

    def _log_change(self, name, ip, up):
        word = "RECOVERED" if up else "DROPPED"
        self._log(f"{word:10} {name} ({ip})")

    def _log(self, msg):
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        try:
            with open(self.logpath, "a") as f:
                f.write(f"{ts}  {msg}\n")
        except OSError:
            pass  # never let logging kill the dashboard

    @property
    def up_count(self):
        return sum(1 for s in self.state.values() if s.up)


class DiscoverMonitor:
    """Polls an HTTP /discover endpoint and tracks each sensor's presence.

    A sensor in the latest successful response is UP; one seen before but now
    absent is DOWN (logged). If the endpoint itself can't be reached, all
    sensors show UNKNOWN and only the endpoint state change is logged, so a
    discovery blip doesn't emit a drop line for every sensor.
    """

    def __init__(self, url, logpath, timeout):
        self.url = url
        self.logpath = logpath
        self.timeout = timeout
        self.reachable = None  # None=unknown, True, False
        self.sensors = {}      # id -> {"name", "up": True/False/None, "since"}
        self._baseline_done = False

    def _fetch(self):
        try:
            req = urllib.request.Request(
                self.url, headers={"Accept": "application/json"}
            )
            with urllib.request.urlopen(req, timeout=self.timeout) as r:
                if r.getcode() != 200:
                    return None
                return json.loads(r.read().decode("utf-8"))
        except (urllib.error.URLError, OSError, ValueError):
            return None

    def poll(self):
        data = self._fetch()
        now = datetime.now()

        if data is None:  # endpoint unreachable
            if self.reachable is not False:
                if self._baseline_done:
                    self._log(f"DISCOVER   unreachable ({self.url})")
                self.reachable = False
            for s in self.sensors.values():
                s["up"] = None
            self._baseline_done = True
            return

        if self.reachable is not True:
            if self._baseline_done and self.reachable is False:
                self._log("DISCOVER   recovered")
            self.reachable = True

        present = {}
        for item in data.get("sensors", []):
            sid = item.get("id")
            if sid:
                present[sid] = item.get("display_name") or sid

        # present sensors -> UP (add new ones dynamically)
        for sid, name in present.items():
            s = self.sensors.get(sid)
            if s is None:
                self.sensors[sid] = {"name": name, "up": True, "since": now}
                if self._baseline_done:
                    self._log(f"APPEARED   {name} ({sid})")
            else:
                s["name"] = name
                if s["up"] is not True:
                    s["up"] = True
                    s["since"] = now
                    if self._baseline_done:
                        self._log(f"RECOVERED  {name} ({sid})")

        # known but absent -> DOWN
        for sid, s in self.sensors.items():
            if sid not in present and s["up"] is not False:
                s["up"] = False
                s["since"] = now
                if self._baseline_done:
                    self._log(f"DROPPED    {s['name']} ({sid})")

        self._baseline_done = True

    def _log(self, msg):
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        try:
            with open(self.logpath, "a") as f:
                f.write(f"{ts}  {msg}\n")
        except OSError:
            pass

    @property
    def up_count(self):
        return sum(1 for s in self.sensors.values() if s["up"] is True)


# --- braille ping-history graph --------------------------------------------
# A braille cell is a 2-wide x 4-tall dot grid, so one character holds two
# samples side by side, each a bar 1-4 dots tall (filled from the bottom).
BRAILLE_BASE = 0x2800
_LEFT_DOTS = (0x40, 0x04, 0x02, 0x01)   # bottom -> top, left sub-column
_RIGHT_DOTS = (0x80, 0x20, 0x10, 0x08)  # bottom -> top, right sub-column


def _col_bits(dots, height):
    bits = 0
    for i in range(min(height, 4)):
        bits |= dots[i]
    return bits


def _braille_line(heights, width):
    """Render bar heights (0-4 dots each) into `width` braille chars,
    most-recent sample on the right, older samples padded blank on the left."""
    n = 2 * width
    h = list(heights)[-n:]
    h = [0] * (n - len(h)) + h
    out = []
    for i in range(0, n, 2):
        out.append(chr(BRAILLE_BASE
                       | _col_bits(_LEFT_DOTS, h[i])
                       | _col_bits(_RIGHT_DOTS, h[i + 1])))
    return "".join(out)


def _device_graph(st, width):
    """Braille sparkline of a device's ping history. Live pings use the full
    height of the cell (4 dots), autoscaled to the window's max ping. A lost
    ping shows a full-height bar coloured red, so drops stand out even though
    they now share the top of the scale with the slowest ping."""
    n = 2 * width
    window = st.history[-n:]
    vals = [s for s in window if s is not None]
    lmax = max(vals) if vals else None
    samples = []  # (height 0-4, lost?, latency)
    for s in window:
        if s is None:                       # lost ping -> full height, red
            samples.append((4, True, None))
        elif not lmax:                      # all-zero window
            samples.append((1, False, s))
        else:                               # 1..4, max ping reaches the top
            samples.append((max(1, round(s / lmax * 4)), False, s))
    samples = [(0, False, None)] * (n - len(samples)) + samples  # left-pad blank

    text = Text()
    for i in range(0, n, 2):
        lh, llost, llat = samples[i]
        rh, rlost, rlat = samples[i + 1]
        code = BRAILLE_BASE | _col_bits(_LEFT_DOTS, lh) | _col_bits(_RIGHT_DOTS, rh)
        if llost or rlost:                  # a dropped ping in this pair -> red
            style = "red"
        else:
            lats = [x for x in (llat, rlat) if x is not None]
            style = _latency_color(max(lats)) if lats else "dim"
        text.append(chr(code), style=style)
    return text


def _latency_color(ms):
    if ms is None:
        return "red"
    return "green" if ms < 50 else "yellow" if ms < 150 else "red"


def _flex_width(console, fixed, struct):
    """Width left for the flexible graph column: the terminal width minus the
    natural widths of the fixed columns and a per-table structural constant
    (box, cell padding and the enclosing Panel). `struct` is calibrated per
    table: 21 for the 6-column device table, 15 for the 4-column sensor one."""
    return max(8, console.width - sum(fixed) - struct)


def _max_graph(width, color):
    """A full-height (max) braille bar — used for API/discovered devices that
    have no ping latency to plot."""
    return Text(_braille_line([4] * (2 * width), width), style=color)


def _fmt_latency(ms):
    if ms is None:
        return Text("up", style="green")
    return Text(f"{ms:.1f} ms", style=_latency_color(ms))


def _fmt_since(dt):
    if dt is None:
        return ""
    secs = int((datetime.now() - dt).total_seconds())
    if secs < 60:
        return f"{secs}s"
    if secs < 3600:
        return f"{secs // 60}m"
    return f"{secs // 3600}h{(secs % 3600) // 60}m"


def local_ips(subnet):
    """Best-effort set of this machine's own IPv4 addresses."""
    ips = set()
    # source IP the OS would use to reach this subnet (no packet is sent)
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect((f"{subnet}.1", 1))
        ips.add(s.getsockname()[0])
        s.close()
    except OSError:
        pass
    # Linux: lists every assigned address
    try:
        out = subprocess.run(["hostname", "-I"], capture_output=True,
                             text=True, timeout=2)
        ips.update(out.stdout.split())
    except (OSError, subprocess.SubprocessError):
        pass
    # hostname resolution as a fallback
    try:
        ips.update(i[4][0] for i in socket.getaddrinfo(socket.gethostname(), None))
    except OSError:
        pass
    return {ip for ip in ips if ip and not ip.startswith("127.")}


def filter_groups(groups, hidden_ips):
    """Drop devices whose IP is in hidden_ips; drop groups left empty."""
    out = {}
    for group, items in groups.items():
        kept = [(n, o) for n, o in items if f"{SUBNET}.{o}" not in hidden_ips]
        if kept:
            out[group] = kept
    return out


def _device_status(st):
    """Return (status_text, latency_renderable) for a DeviceState."""
    if st.up:
        return Text("\u25cf UP", style="bold green"), _fmt_latency(st.latency)
    return Text("\u25cf DOWN", style="bold red"), Text("\u2014", style="dim red")


def render(mon: Monitor, interval: float, console: Console,
           compressed: bool = False) -> Panel:
    box_style = box.SIMPLE if compressed else box.SIMPLE_HEAVY
    table = Table(box=box_style, expand=True, pad_edge=False)
    table.add_column("Device", style="bold", no_wrap=True)
    table.add_column("IP", style="dim", no_wrap=True)
    table.add_column("Status", justify="center", no_wrap=True)
    table.add_column("Latency", justify="right", no_wrap=True)
    table.add_column("Since", justify="right", style="dim", no_wrap=True)
    table.add_column("Ping", justify="right", no_wrap=True, ratio=1)

    # natural widths of the fixed columns so the graph fills whatever is left
    dev = [cell_len("Device")]
    lat = [cell_len("Latency")]
    since = [cell_len("Since")]
    for group, items in mon.groups.items():
        if not compressed:
            dev.append(cell_len(group.upper()))
        for name, octet in items:
            st = mon.state[f"{SUBNET}.{octet}"]
            dev.append(cell_len(("" if compressed else "  ") + name))
            lat.append(cell_len(_device_status(st)[1].plain))
            since.append(cell_len(_fmt_since(st.since)))
    # IP <= "192.168.2.255" (13); Status <= "● DOWN" (6)
    gw = _flex_width(console, [max(dev), 13, 6, max(lat), max(since)], 21)

    zebra = 0  # counts data rows only, for alternating background

    def add_device(name, octet, indent):
        nonlocal zebra
        ip = f"{SUBNET}.{octet}"
        st = mon.state[ip]
        status, lat = _device_status(st)
        rowstyle = ZEBRA_BG if zebra % 2 else None
        zebra += 1
        table.add_row(f"{indent}{name}", ip, status, lat,
                      _fmt_since(st.since), _device_graph(st, gw),
                      style=rowstyle)

    if compressed:
        # flat list, no category headers, no section gaps
        for items in mon.groups.values():
            for name, octet in items:
                add_device(name, octet, "")
    else:
        for group, items in mon.groups.items():
            table.add_row(Text(group.upper(), style="bold cyan"),
                          "", "", "", "", "", style=HEADER_BG)
            for name, octet in items:
                add_device(name, octet, "  ")
            table.add_section()

    up, total = mon.up_count, len(mon.state)
    tcolor = "green" if up == total else "red" if up == 0 else "yellow"
    title = Text(
        f"Rover Network Monitor — {up}/{total} up — {datetime.now():%H:%M:%S}",
        style=f"bold {tcolor}",
    )
    extra = " · self hidden" if mon.hidden else ""
    subtitle = Text(
        f"refresh {interval:g}s · log: {mon.logpath}{extra} · Ctrl-C to quit",
        style="dim",
    )
    pad = (0, 1)
    return Panel(table, title=title, subtitle=subtitle,
                 border_style=tcolor, padding=pad)


def render_sensors(dmon: DiscoverMonitor, console: Console,
                   compressed: bool = False) -> Panel:
    box_style = box.SIMPLE if compressed else box.SIMPLE_HEAVY
    table = Table(box=box_style, expand=True, pad_edge=False)
    table.add_column("Sensor", style="bold", no_wrap=True)
    table.add_column("Status", justify="center", no_wrap=True)
    table.add_column("Since", justify="right", style="dim", no_wrap=True)
    table.add_column("Ping", justify="right", no_wrap=True, ratio=1)

    name = [cell_len("Sensor")]
    stat = [cell_len("Status")]
    since = [cell_len("Since")]
    for s in dmon.sensors.values():
        up = s["up"]
        txt = "\u25cf UP" if up is True else "\u25cf DOWN" if up is False else "\u25cf UNKNOWN"
        name.append(cell_len(s["name"]))
        stat.append(cell_len(txt))
        since.append(cell_len(_fmt_since(s["since"])))
    gw = _flex_width(console, [max(name), max(stat), max(since)], 15)

    if not dmon.sensors:
        msg = "discover unreachable" if dmon.reachable is False else "none discovered yet"
        table.add_row(Text(f"({msg})", style="dim"), "", "", "")
    else:
        for i, (sid, s) in enumerate(sorted(dmon.sensors.items(),
                                     key=lambda kv: kv[1]["name"].lower())):
            up = s["up"]
            if up is True:
                status = Text("\u25cf UP", style="bold green")
                gcolor = "green"
            elif up is False:
                status = Text("\u25cf DOWN", style="bold red")
                gcolor = "red"
            else:
                status = Text("\u25cf UNKNOWN", style="bold yellow")
                gcolor = "yellow"
            rowstyle = ZEBRA_BG if i % 2 else None
            # API/discovered devices have no latency \u2014 show a full (max) bar
            table.add_row(s["name"], status, _fmt_since(s["since"]),
                          _max_graph(gw, gcolor), style=rowstyle)

    up, total = dmon.up_count, len(dmon.sensors)
    if dmon.reachable is False:
        tcolor = "red"
        title = Text(f"Sensors — discover UNREACHABLE — {dmon.url}",
                     style="bold red")
    else:
        tcolor = "green" if total and up == total else "yellow" if up else "red"
        title = Text(f"Sensors — {up}/{total} up — {dmon.url}",
                     style=f"bold {tcolor}")
    return Panel(table, title=title, border_style=tcolor, padding=(0, 1))


def compose(mon, dmon, interval, console, compressed=False):
    device_panel = render(mon, interval, console, compressed)
    if dmon is None:
        return device_panel
    return Group(device_panel, render_sensors(dmon, console, compressed))


def parse_args():
    p = argparse.ArgumentParser(description="Live network status dashboard.")
    p.add_argument("-i", "--interval", type=float, default=2.0,
                   help="seconds between refreshes (default: 2)")
    p.add_argument("-t", "--timeout", type=float, default=1.0,
                   help="ping timeout in seconds (default: 1)")
    p.add_argument("-l", "--log", default=DEFAULT_LOG,
                   help=f"log file path (default: {DEFAULT_LOG})")
    p.add_argument("--discover-url", default=DEFAULT_DISCOVER,
                   help=f"sensor discovery endpoint (default: {DEFAULT_DISCOVER})")
    p.add_argument("--no-discover", action="store_true",
                   help="disable the /discover sensor monitor")
    p.add_argument("--once", action="store_true",
                   help="print a single snapshot and exit")
    p.add_argument("-c", "--compressed", action="store_true",
                   help="flat view: no categories, no spacing")
    p.add_argument("--show-self", action="store_true",
                   help="don't hide this machine's own IP")
    return p.parse_args()


def _poll_all(mon, dmon):
    """Poll the ping sweep and the discover endpoint concurrently."""
    with ThreadPoolExecutor(max_workers=2) as ex:
        futs = [ex.submit(mon.poll)]
        if dmon is not None:
            futs.append(ex.submit(dmon.poll))
        for f in futs:
            f.result()


def main():
    args = parse_args()
    console = Console()

    hidden = set() if args.show_self else local_ips(SUBNET)
    groups = filter_groups(DEVICES, hidden)
    mon = Monitor(groups, timeout=args.timeout, logpath=args.log, hidden=hidden)
    dmon = None
    if not args.no_discover:
        dmon = DiscoverMonitor(args.discover_url, logpath=args.log,
                               timeout=max(args.timeout, 2.0))

    if args.once:
        _poll_all(mon, dmon)
        console.print(compose(mon, dmon, args.interval, console, args.compressed))
        return

    try:
        _poll_all(mon, dmon)  # first frame has data immediately
        with Live(compose(mon, dmon, args.interval, console, args.compressed),
                  console=console, screen=True, auto_refresh=False) as live:
            while True:
                time.sleep(args.interval)
                _poll_all(mon, dmon)
                live.update(compose(mon, dmon, args.interval, console,
                                    args.compressed))
                live.refresh()
    except KeyboardInterrupt:
        console.print("[dim]stopped.[/dim]")


if __name__ == "__main__":
    main()
